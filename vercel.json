{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/.next/serverless/:1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next"
}